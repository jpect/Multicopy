<Window x:Class="Multicopy2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Multicopy" Height="700" Width="520"
        ResizeMode="CanResize"
        MinHeight="600" MinWidth="500"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Multicopy" FontSize="22" FontWeight="Bold" Foreground="#1976D2"/>
            <TextBlock Text="Copy a folder, files, or whole drive to multiple USB drives"
                       FontSize="12" Foreground="#757575" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Source picker -->
        <Border Grid.Row="1"
                BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4"
                Padding="12,10" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionLabel}" Text="SOURCE" Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <RadioButton x:Name="ModeFolder"   Content="Folder"           IsChecked="True"  Margin="0,0,16,0" Checked="SourceMode_Changed"/>
                    <RadioButton x:Name="ModeFiles"    Content="Files"            Margin="0,0,16,0" Checked="SourceMode_Changed"/>
                    <RadioButton x:Name="ModeDrive"    Content="Entire drive"     Checked="SourceMode_Changed"/>
                </StackPanel>

                <!-- Folder mode -->
                <Grid x:Name="FolderModePanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SourceBox" Grid.Column="0"
                                 IsReadOnly="True" Padding="8,6" VerticalContentAlignment="Center"
                                 Background="#F5F5F5" BorderBrush="#CCCCCC" FontSize="12"
                                 Text="(no folder selected)"/>
                        <Button Grid.Column="1" Content="Browse..." Margin="8,0,0,0"
                                Style="{StaticResource SecondaryButton}" Click="BrowseSource_Click"/>
                    </Grid>
                    <CheckBox x:Name="FolderIncludeName" Grid.Row="1" Margin="0,8,0,0"
                              Content="Place inside subfolder (preserve folder name)"
                              FontSize="11"/>
                </Grid>

                <!-- Files mode -->
                <Grid x:Name="FilesModePanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="80"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="FilesList" ItemsSource="{Binding FileItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Padding="6,3" FontSize="11"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="+ Add files..." Click="AddFiles_Click"
                                Style="{StaticResource SecondaryButton}"/>
                        <Button Content="Clear" Click="ClearFiles_Click" Margin="6,0,0,0"
                                Style="{StaticResource SecondaryButton}"/>
                    </StackPanel>
                </Grid>

                <!-- Drive mode -->
                <Grid x:Name="DriveModePanel" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="SourceDriveCombo" Grid.Column="0" Padding="6"
                              ItemsSource="{Binding SourceDriveItems}" DisplayMemberPath="DisplayText"
                              FontSize="12"/>
                    <Button Grid.Column="1" Content="⟳" Margin="6,0,0,0"
                            Style="{StaticResource SecondaryButton}" Click="RescanSourceDrives_Click"
                            ToolTip="Rescan source drives"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Destination drives -->
        <Grid Grid.Row="2" Margin="0,0,0,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource SectionLabel}" Text="DESTINATION USB DRIVES" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="⟳  Rescan" Style="{StaticResource SecondaryButton}" Click="Rescan_Click"/>
            </Grid>

            <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="DriveItemsControl" ItemsSource="{Binding DriveItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Padding="6,4" Margin="4,2" Cursor="Hand">
                                    <TextBlock Text="{Binding DisplayText}" FontSize="12" VerticalAlignment="Center"/>
                                </CheckBox>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Options -->
        <Border Grid.Row="3" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4"
                Padding="12,10" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionLabel}" Text="OPTIONS" Margin="0,0,0,8"/>
                <CheckBox x:Name="OptionEraseBefore" Content="Erase drive contents before copying" FontSize="12" Margin="0,3"/>
                <CheckBox x:Name="OptionOverwrite"   Content="Overwrite existing files"            FontSize="12" Margin="0,3"/>
                <StackPanel Orientation="Horizontal" Margin="0,3">
                    <CheckBox x:Name="OptionSetName" Content="Set volume name:" FontSize="12" VerticalAlignment="Center"
                              Checked="OptionSetName_Changed" Unchecked="OptionSetName_Changed"/>
                    <TextBox x:Name="OptionVolumeNameBox" Width="150" Margin="10,0,0,0" Padding="6,3"
                             IsEnabled="False" FontSize="12" BorderBrush="#CCCCCC" MaxLength="32"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Start -->
        <Button Grid.Row="4" x:Name="StartButton" Content="Start Copy  →"
                FontSize="14" FontWeight="SemiBold" Padding="0,12"
                Style="{StaticResource PrimaryButton}" Click="StartCopy_Click"/>
    </Grid>
</Window>
